<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvHeaderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Result"
            android:textColor="#BCBCBC"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardHero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#2D4635"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderLabel">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="30dp">

                <TextView
                    android:id="@+id/tvDetectedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FACE SHAPE DETECTED"
                    android:textColor="#9E896A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvFaceShapeResult"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-10dp"
                    app:layout_constraintEnd_toStartOf="@+id/ivCheck"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDetectedLabel" />

                <ImageView
                    android:id="@+id/ivCheck"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:layout_constraintBottom_toBottomOf="@id/tvFaceShapeResult"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvFaceShapeResult"
                    app:tint="#FFFFFF" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvFaceShapeResult">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:drawable/editbox_dropdown_light_frame"
                        android:paddingHorizontal="12dp"
                        android:text="Most Versatile"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:backgroundTint="#40FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@android:drawable/editbox_dropdown_light_frame"
                        android:paddingHorizontal="12dp"
                        android:text="Balanced Proportions"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:backgroundTint="#40FFFFFF" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/descWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cardHero">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#2D4635" />

            <TextView
                android:id="@+id/tvFaceShapeDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#BCBCBC"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAnalysisLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Face Shape Analysis"
            android:textColor="#333333"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/descWrapper" />

        <LinearLayout
            android:id="@+id/scoresContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvAnalysisLabel" />

        <TextView
            android:id="@+id/tvRecLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Recommended Styles"
            android:textColor="#333333"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scoresContainer" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerStyles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvRecLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/recyclerStyles">

            <Button
                android:id="@+id/btnBrowse"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="2"
                android:backgroundTint="#2D4635"
                android:text="Browse Hairstyles"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:backgroundTint="#F2EFE9"
                android:text="Retry"
                android:textAllCaps="false"
                android:textColor="#333333" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>