<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Hairstyle image -->
        <ImageView
            android:id="@+id/imgStyle"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_hairstyle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Match percentage badge (top-right corner) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMatchPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/bb_gold"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">


        </com.google.android.material.card.MaterialCardView>

        <!-- SAVE ICON (UPDATED: ImageView instead of ImageButton) -->
        <ImageView
            android:id="@+id/ivSave"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_bookmark_outline"
            android:padding="6dp"
            android:background="@drawable/bg_icon_btn_white"
            android:contentDescription="Save style"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Gradient overlay at bottom of image -->
        <View
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:background="@drawable/gradient_image_bottom"
            app:layout_constraintBottom_toBottomOf="@id/imgStyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Info section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/imgStyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Name -->
            <TextView
                android:id="@+id/tvStyleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Textured Crop"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/bb_text_dark"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Trend + Maintenance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvTrend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trending"
                    android:textSize="11sp"
                    android:textColor="@color/bb_deep_green"
                    android:background="@drawable/bg_chip_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"/>

                <TextView
                    android:id="@+id/tvMaintenance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textSize="11sp"
                    android:textColor="@color/bb_text_muted"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>