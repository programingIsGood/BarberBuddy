<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image section (dark green bg with scissors icon) -->
            <FrameLayout
                android:id="@+id/heroFrame"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@color/bb_deep_green">

                <!-- Hairstyle image -->
                <ImageView
                    android:id="@+id/imgStyleDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_hairstyle"/>

                <!-- Gradient overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_detail_overlay"/>

                <!-- Toolbar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="48dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_arrow_back_white"
                        android:background="@drawable/bg_icon_btn_dark"
                        android:contentDescription="Back"/>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <ImageButton
                        android:id="@+id/btnSaveDetail"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_bookmark_outline"
                        android:background="@drawable/bg_icon_btn_dark"
                        android:contentDescription="Save"
                        android:layout_marginEnd="8dp"/>

                    <ImageButton
                        android:id="@+id/btnShareDetail"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_share_white"
                        android:background="@drawable/bg_icon_btn_dark"
                        android:contentDescription="Share"/>
                </LinearLayout>

                <!-- Match badge -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMatchBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/bb_gold"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <TextView
                        android:id="@+id/tvMatchBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="98% match for Oval Face"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/bb_text_dark"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Content section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp">

                <!-- Name -->
                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Textured Crop"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/bb_text_dark"
                    android:lineSpacingMultiplier="1.1"/>

                <!-- Attribute chips row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvDetailTrend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trending"
                        android:textSize="12sp"
                        android:textColor="@color/bb_deep_green"
                        android:background="@drawable/bg_chip_green"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailMaintenanceChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Short"
                        android:textSize="12sp"
                        android:textColor="@color/bb_text_muted"
                        android:background="@drawable/bg_chip_gray"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailMaintenanceLevelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low Maintenance"
                        android:textSize="12sp"
                        android:textColor="@color/bb_text_muted"
                        android:background="@drawable/bg_chip_gray"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bb_divider"
                    android:layout_marginBottom="20dp"/>

                <!-- About Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT THIS STYLE"
                    android:textSize="11sp"
                    android:textColor="@color/bb_text_muted"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A modern, versatile cut featuring textured ends and a clean fade on the sides."
                    android:textSize="15sp"
                    android:textColor="@color/bb_text_dark"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="24dp"/>

                <!-- Maintenance Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAINTENANCE"
                    android:textSize="11sp"
                    android:textColor="@color/bb_text_muted"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailTips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Apply matte clay to damp hair and rough-dry for texture. Trim sides every 3 weeks."
                    android:textSize="15sp"
                    android:textColor="@color/bb_text_dark"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="24dp"/>

                <!-- Suitable For Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUITABLE FOR"
                    android:textSize="11sp"
                    android:textColor="@color/bb_text_muted"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvSuitableFor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Oval, Round, Square faces"
                    android:textSize="15sp"
                    android:textColor="@color/bb_text_dark"
                    android:layout_marginBottom="32dp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Buttons (fixed) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp"
        android:elevation="16dp"
        app:layout_anchor="@id/scrollContent"
        app:layout_anchorGravity="bottom">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTryAR"
            style="@style/BB.Button.Green"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Try in AR"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareStyle"
            style="@style/BB.Button.Outline"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Share"
            android:minWidth="80dp"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
