<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Style name label at top -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStyleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bb_gold"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStyleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Textured Crop - Overlay"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/bb_text_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Camera preview area (full screen) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/arPreviewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- AR Overlay — hair style silhouette drawn on top of camera -->
    <ImageView
        android:id="@+id/ivHairOverlay"
        android:layout_width="260dp"
        android:layout_height="340dp"
        android:src="@drawable/ic_face_oval"
        android:scaleType="fitCenter"
        android:alpha="0.75"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomArPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp"/>

    <!-- Face landmark overlay for AR -->
    <com.example.barberbuddy.LandmarkOverlayView
        android:id="@+id/arLandmarkOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom panel -->
    <LinearLayout
        android:id="@+id/bottomArPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="32dp"
        android:paddingTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Style switcher row -->
        <LinearLayout
            android:id="@+id/llStyleSwitcher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <!-- Style thumbnails will be added dynamically -->
        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                style="@style/BB.Button.Gold"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📷  Capture"
                android:layout_marginEnd="12dp"/>

            <ImageButton
                android:id="@+id/btnCloseAR"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_icon_btn_dark"
                android:contentDescription="Close"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
